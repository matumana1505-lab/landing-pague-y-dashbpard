# Gemini API Configuration
# Get your API key from: https://ai.google.dev/tutorials/setup
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth (v4) Configuration
# Generate a secret with: openssl rand -base64 32
# IMPORTANT: changing this value invalidates existing session cookies and causes
# JWT_SESSION_ERROR / JWEDecryptionFailed for already-signed-in users.
NEXTAUTH_SECRET=your_nextauth_secret_here
# Public base URL of the app (e.g. http://localhost:3000 in dev).
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (Google Cloud Console -> APIs & Services -> Credentials)
# Authorized redirect URI must be: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
